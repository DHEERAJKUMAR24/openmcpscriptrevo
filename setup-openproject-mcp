#Requires -Version 5.1
<#
.SYNOPSIS
    One-shot local setup for the OpenProject MCP Server.
    Run via:
        Set-ExecutionPolicy Bypass -Scope Process -Force; irm <RAW_GITHUB_URL> | iex
#>

$ErrorActionPreference = "Stop"

# ============================================================
# STEP 0 - Banner
# ============================================================
Clear-Host
Write-Host ""
Write-Host "============================================================" -ForegroundColor Cyan
Write-Host "  OpenProject MCP Server - Local Setup" -ForegroundColor Cyan
Write-Host "  Running as Windows user: $env:USERNAME" -ForegroundColor Cyan
Write-Host "============================================================" -ForegroundColor Cyan
Write-Host ""

# ============================================================
# Helper: refresh PATH in current session after winget install
# ============================================================
function Refresh-Path {
    $machinePath = [System.Environment]::GetEnvironmentVariable('Path', 'Machine')
    $userPath    = [System.Environment]::GetEnvironmentVariable('Path', 'User')
    $env:Path    = $machinePath + ';' + $userPath
}

function Invoke-Native {
    param(
        [Parameter(Mandatory = $true)]
        [string]$FilePath,

        [string[]]$Arguments = @(),

        [string]$FailureMessage = "Command failed: $FilePath"
    )

    & $FilePath @Arguments
    if ($LASTEXITCODE -ne 0) {
        throw "$FailureMessage (exit code: $LASTEXITCODE)"
    }
}

function Resolve-UvExe {
    $knownUvPaths = @(
        "$env:USERPROFILE\.local\bin\uv.exe",
        "$env:USERPROFILE\.cargo\bin\uv.exe",
        "$env:LOCALAPPDATA\uv\bin\uv.exe",
        "$env:APPDATA\uv\bin\uv.exe"
    )

    foreach ($path in $knownUvPaths) {
        if (Test-Path $path) {
            return $path
        }
    }

    $uvCmd = Get-Command uv -ErrorAction SilentlyContinue
    if ($uvCmd) {
        return $uvCmd.Source
    }

    return $null
}

# ============================================================
# Helper: check winget is available
# ============================================================
function Assert-Winget {
    if (-not (Get-Command winget -ErrorAction SilentlyContinue)) {
        Write-Host "  [ERROR] winget is not available on this machine." -ForegroundColor Red
        Write-Host "  Please install 'App Installer' from the Microsoft Store and re-run." -ForegroundColor Yellow
        exit 1
    }
}

# ============================================================
# STEP 1 - Git
# ============================================================
Write-Host "[ 1/3 ] Checking Git..." -ForegroundColor Yellow
if (Get-Command git -ErrorAction SilentlyContinue) {
    $gitVer = (git --version)
    Write-Host "  [SKIP] Git already installed: $gitVer" -ForegroundColor Green
} else {
    Assert-Winget
    Write-Host "  [INFO] Git not found. Installing via winget..." -ForegroundColor Yellow
    Invoke-Native -FilePath 'winget' -Arguments @(
        'install', '--id', 'Git.Git', '--accept-package-agreements', '--accept-source-agreements', '--silent'
    ) -FailureMessage 'Git installation failed'
    Refresh-Path
    if (Get-Command git -ErrorAction SilentlyContinue) {
        Write-Host "  [ OK ] Git installed successfully." -ForegroundColor Green
    } else {
        Write-Host "  [ERROR] Git installation failed. Install manually from https://git-scm.com" -ForegroundColor Red
        exit 1
    }
}

# ============================================================
# STEP 2 - uv (manages Python internally - no system Python needed)
# ============================================================
Write-Host ""
Write-Host "[ 2/3 ] Checking uv (Python package manager)..." -ForegroundColor Yellow
if (Get-Command uv -ErrorAction SilentlyContinue) {
    $uvVer = (uv --version)
    Write-Host "  [SKIP] uv already installed: $uvVer" -ForegroundColor Green
} else {
    Assert-Winget
    Write-Host "  [INFO] uv not found. Installing via winget..." -ForegroundColor Yellow
    Invoke-Native -FilePath 'winget' -Arguments @(
        'install', '--id', 'astral-sh.uv', '--accept-package-agreements', '--accept-source-agreements', '--silent'
    ) -FailureMessage 'uv installation failed'
    Refresh-Path
    $env:Path = "$env:USERPROFILE\.local\bin;$env:USERPROFILE\.cargo\bin;" + $env:Path
    if (Get-Command uv -ErrorAction SilentlyContinue) {
        Write-Host "  [ OK ] uv installed successfully." -ForegroundColor Green
    } else {
        Write-Host "  [ERROR] uv installation failed. Install manually from https://docs.astral.sh/uv/" -ForegroundColor Red
        exit 1
    }
}

# ============================================================
# STEP 3 - Ensure Python 3.11 is available via uv
# ============================================================
Write-Host ""
Write-Host "[ 3/3 ] Checking Python (via uv)..." -ForegroundColor Yellow
$script:UvExe = Resolve-UvExe
if (-not $script:UvExe) {
    Write-Host "  [ERROR] uv is still not available after installation." -ForegroundColor Red
    exit 1
}
Invoke-Native -FilePath $script:UvExe -Arguments @('python', 'install', '3.11') -FailureMessage 'Python 3.11 installation via uv failed'
Write-Host "  [ OK ] Python 3.11 ready." -ForegroundColor Green

# ============================================================
# STEP 4 - Collect user info
# ============================================================
Write-Host ""
Write-Host "============================================================" -ForegroundColor Cyan
Write-Host "  Identity and Credentials Setup" -ForegroundColor Cyan
Write-Host "============================================================" -ForegroundColor Cyan
Write-Host ""

$DefaultName = "$env:USERNAME Ai Mcp"
$Username = Read-Host "  Your name [default: $DefaultName]"
if ([string]::IsNullOrWhiteSpace($Username)) { $Username = $DefaultName }

Write-Host ""
$DefaultUrl = "http://10.10.12.23"
$OpUrl = Read-Host "  OpenProject URL [default: $DefaultUrl]"
if ([string]::IsNullOrWhiteSpace($OpUrl)) { $OpUrl = $DefaultUrl }
$OpUrl = $OpUrl.TrimEnd('/')

Write-Host ""
Write-Host "  Opening your API token page in the browser..." -ForegroundColor Yellow
Start-Process "$OpUrl/my/access_token"
$DisplayAccessTokenUrl = "$OpUrl/my/access_token"
Write-Host ""
Write-Host "  How to get your API key:" -ForegroundColor DarkGray
Write-Host "    1. The page $DisplayAccessTokenUrl just opened in your browser" -ForegroundColor DarkGray
Write-Host "    2. Click the [ + API token ] button" -ForegroundColor DarkGray
Write-Host "    3. Give it any name, then click Save" -ForegroundColor DarkGray
Write-Host "    4. Copy the token shown and paste it below" -ForegroundColor DarkGray
Write-Host ""
$OpApiKey = Read-Host "  Your OpenProject API Key"
if ([string]::IsNullOrWhiteSpace($OpApiKey)) {
    Write-Host "  [ERROR] API Key cannot be empty." -ForegroundColor Red
    exit 1
}

# ============================================================
# STEP 5 - Generate unique MCP secret
# ============================================================
$UniqueHash = (New-Guid).ToString().Replace('-', '').Substring(0, 12)
$McpSecret  = "mcp-$Username-$UniqueHash"
Write-Host ""
Write-Host "  Generated MCP Secret: $McpSecret" -ForegroundColor Green
Write-Host "  (Saved to D:\openproject-mcp\credentials.txt)" -ForegroundColor DarkGray

# ============================================================
# STEP 6 - Create D:\openproject-mcp
# ============================================================
Write-Host ""
Write-Host "============================================================" -ForegroundColor Cyan
Write-Host "  Directory Setup" -ForegroundColor Cyan
Write-Host "============================================================" -ForegroundColor Cyan

$InstallDir = 'D:\openproject-mcp'
if (Test-Path $InstallDir) {
    Write-Host "  [SKIP] $InstallDir already exists." -ForegroundColor Green
} else {
    New-Item -ItemType Directory -Path $InstallDir -Force | Out-Null
    Write-Host "  [ OK ] Created $InstallDir" -ForegroundColor Green
}

# ============================================================
# STEP 7 - Clone or update repo
# ============================================================
Write-Host ""
Write-Host "============================================================" -ForegroundColor Cyan
Write-Host "  Repository Setup" -ForegroundColor Cyan
Write-Host "============================================================" -ForegroundColor Cyan

$RepoDir = "$InstallDir\openproject-mcp-server"
if (Test-Path "$RepoDir\.git") {
    Write-Host "  [SKIP] Repository already exists. Pulling latest changes..." -ForegroundColor Green
    Push-Location $RepoDir
    Invoke-Native -FilePath 'git' -Arguments @('pull') -FailureMessage 'git pull failed'
    Pop-Location
} else {
    Write-Host "  [INFO] Cloning openproject-mcp-server..." -ForegroundColor Yellow
    Invoke-Native -FilePath 'git' -Arguments @('clone', 'https://github.com/andyeverything/openproject-mcp-server.git', $RepoDir) -FailureMessage 'git clone failed'
    Write-Host "  [ OK ] Repository cloned to $RepoDir" -ForegroundColor Green
}

# ============================================================
# STEP 8 - Install Python dependencies via uv
# ============================================================
Write-Host ""
Write-Host "============================================================" -ForegroundColor Cyan
Write-Host "  Python Environment Setup (uv sync)" -ForegroundColor Cyan
Write-Host "============================================================" -ForegroundColor Cyan

Push-Location $RepoDir
Write-Host "  [INFO] Running uv sync..." -ForegroundColor Yellow
Invoke-Native -FilePath $script:UvExe -Arguments @('sync') -FailureMessage 'uv sync failed'
Write-Host "  [ OK ] Python environment ready." -ForegroundColor Green
Pop-Location

# ============================================================
# STEP 9 - Write .env file
# ============================================================
Write-Host ""
Write-Host "============================================================" -ForegroundColor Cyan
Write-Host "  Environment Configuration" -ForegroundColor Cyan
Write-Host "============================================================" -ForegroundColor Cyan

$EnvPath    = "$RepoDir\.env"
$EnvContent = "OPENPROJECT_URL=$OpUrl`nOPENPROJECT_API_KEY=$OpApiKey"
[System.IO.File]::WriteAllText($EnvPath, $EnvContent, [System.Text.UTF8Encoding]::new($false))
Write-Host "  [ OK ] .env written to $EnvPath" -ForegroundColor Green

# ============================================================
# STEP 10 - Test API connection and list projects
# ============================================================
Write-Host ""
Write-Host "============================================================" -ForegroundColor Cyan
Write-Host "  Testing OpenProject API Connection" -ForegroundColor Cyan
Write-Host "============================================================" -ForegroundColor Cyan
Write-Host "  Connecting to $OpUrl/api/v3/projects ..." -ForegroundColor Yellow

try {
    $AuthBytes = [System.Text.Encoding]::ASCII.GetBytes("apikey:$OpApiKey")
    $AuthB64   = [System.Convert]::ToBase64String($AuthBytes)
    $Headers   = @{ Authorization = "Basic $AuthB64" }

    $Response = Invoke-RestMethod `
        -Uri "$OpUrl/api/v3/projects" `
        -Headers $Headers `
        -Method Get `
        -ErrorAction Stop

    $Projects = $Response._embedded.elements
    $Count    = $Projects.Count

    Write-Host ""
    Write-Host "  SUCCESS! Authenticated as: $Username" -ForegroundColor Green
    Write-Host "  Found $Count project(s):" -ForegroundColor Green
    Write-Host ""
    $i = 1
    foreach ($proj in $Projects) {
        Write-Host ("  {0,3}. {1}" -f $i, $proj.name) -ForegroundColor White
        $i++
    }
} catch {
    Write-Host ""
    Write-Host "  [ERROR] Could not connect to OpenProject." -ForegroundColor Red
    Write-Host "  Details: $($_.Exception.Message)" -ForegroundColor Red
    Write-Host ""
    Write-Host "  Checklist:" -ForegroundColor Yellow
    Write-Host "    - Is OpenProject running at $OpUrl ?" -ForegroundColor Yellow
    Write-Host "    - Is your API key correct? (Avatar > My account > Access tokens)" -ForegroundColor Yellow
    Write-Host "    - Are you on the right network / VPN?" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "  Re-run this script after fixing the issue." -ForegroundColor Yellow
    exit 1
}

# ============================================================
# STEP 11 - Auto-register MCP in all detected AI tools
# ============================================================
$script:McpServerName = "openproject-$($Username.Replace(' ','-').ToLower())-local"
$script:McpEntryPoint = "$RepoDir\openproject-mcp-fastmcp.py"
$script:McpRepoDir    = $RepoDir
$script:McpOpUrl      = $OpUrl
$script:McpApiKey     = $OpApiKey

# Resolve full path to uv.exe - AI tools launch with minimal PATH so bare 'uv' fails
$script:UvExe = Resolve-UvExe
if ($script:UvExe) {
    Write-Host "  [INFO] uv resolved to: $($script:UvExe)" -ForegroundColor DarkGray
} else {
    Write-Host "  [ERROR] Could not resolve uv.exe for MCP registration." -ForegroundColor Red
    exit 1
}

# -------------------------------------------------------
# Core server object - used by every tool
# No cwd: --directory tells uv where the project is.
# env block means credentials travel with the config.
# -------------------------------------------------------
function New-McpServerObj {
    param([string]$Format)   # 'claude' | 'vscode-mcp' | 'vscode-settings' | 'zed'
    $EnvObj = [ordered]@{
        OPENPROJECT_URL     = $script:McpOpUrl
        OPENPROJECT_API_KEY = $script:McpApiKey
    }
    $BaseArgs = @('run', '--directory', $script:McpRepoDir, 'python', $script:McpEntryPoint)
    if ($Format -eq 'vscode-mcp' -or $Format -eq 'vscode-settings') {
        return [ordered]@{ type = 'stdio'; command = $script:UvExe; args = $BaseArgs; env = $EnvObj }
    } else {
        return [ordered]@{ command = $script:UvExe; args = $BaseArgs; env = $EnvObj }
    }
}

# -------------------------------------------------------
# Merge helper - reads JSON, inserts server, writes back
# -------------------------------------------------------
function Register-McpTool {
    param(
        [string]$ToolName,
        [string]$ConfigPath,
        [string]$Format   # 'claude' | 'vscode-mcp' | 'vscode-settings' | 'zed'
    )

    $ConfigDir = Split-Path $ConfigPath
    if (-not (Test-Path $ConfigDir)) {
        Write-Host "  [SKIP] $ToolName - not installed." -ForegroundColor DarkGray
        return
    }

    $ServerObj = New-McpServerObj -Format $Format

    if (Test-Path $ConfigPath) {
        try   { $Config = Get-Content $ConfigPath -Raw | ConvertFrom-Json -ErrorAction Stop }
        catch { $Config = [PSCustomObject]@{} }
    } else {
        $Config = [PSCustomObject]@{}
    }

    switch ($Format) {
        'vscode-mcp' {
            # VS Code dedicated mcp.json  ->  { "servers": { ... }, "inputs": [] }
            if (-not $Config.PSObject.Properties['servers']) {
                $Config | Add-Member -NotePropertyName 'servers' -NotePropertyValue ([PSCustomObject]@{})
            }
            if (-not $Config.PSObject.Properties['inputs']) {
                $Config | Add-Member -NotePropertyName 'inputs' -NotePropertyValue @()
            }
            $Config.servers | Add-Member -NotePropertyName $script:McpServerName -NotePropertyValue $ServerObj -Force
        }
        'vscode-settings' {
            # Older VS Code settings.json  ->  { "mcp": { "servers": { ... } } }
            if (-not $Config.PSObject.Properties['mcp']) {
                $Config | Add-Member -NotePropertyName 'mcp' -NotePropertyValue ([PSCustomObject]@{ servers = [PSCustomObject]@{} })
            }
            if (-not $Config.mcp.PSObject.Properties['servers']) {
                $Config.mcp | Add-Member -NotePropertyName 'servers' -NotePropertyValue ([PSCustomObject]@{})
            }
            $Config.mcp.servers | Add-Member -NotePropertyName $script:McpServerName -NotePropertyValue $ServerObj -Force
        }
        'zed' {
            # Zed settings.json -> { "context_servers": { ... } }
            if (-not $Config.PSObject.Properties['context_servers']) {
                $Config | Add-Member -NotePropertyName 'context_servers' -NotePropertyValue ([PSCustomObject]@{})
            }
            $Config.context_servers | Add-Member -NotePropertyName $script:McpServerName -NotePropertyValue $ServerObj -Force
        }
        default {
            # Claude Desktop, Cursor, Windsurf, etc.  ->  { "mcpServers": { ... } }
            if (-not $Config.PSObject.Properties['mcpServers']) {
                $Config | Add-Member -NotePropertyName 'mcpServers' -NotePropertyValue ([PSCustomObject]@{})
            }
            $Config.mcpServers | Add-Member -NotePropertyName $script:McpServerName -NotePropertyValue $ServerObj -Force
        }
    }

    $Json = $Config | ConvertTo-Json -Depth 10
    [System.IO.File]::WriteAllText($ConfigPath, $Json, [System.Text.UTF8Encoding]::new($false))
    Write-Host "  [ OK ] $ToolName" -ForegroundColor Green
    Write-Host "         $ConfigPath" -ForegroundColor DarkGray
}

# -------------------------------------------------------
# Claude Code CLI - official CLI, no JSON editing needed
# -------------------------------------------------------
function Register-ClaudeCodeCli {
    if (-not (Get-Command claude -ErrorAction SilentlyContinue)) {
        Write-Host "  [SKIP] Claude Code CLI - not found in PATH." -ForegroundColor DarkGray
        return
    }
    # Remove stale entry first (ignore errors if it doesn't exist)
    & claude mcp remove $script:McpServerName --scope user 2>$null | Out-Null
    & claude mcp add $script:McpServerName `
        --scope user `
        -e "OPENPROJECT_URL=$($script:McpOpUrl)" `
        -e "OPENPROJECT_API_KEY=$($script:McpApiKey)" `
        -- "$($script:UvExe)" run --directory "$($script:McpRepoDir)" python "$($script:McpEntryPoint)" 2>&1 | Out-Null
    if ($LASTEXITCODE -ne 0) {
        throw "claude mcp add failed (exit code: $LASTEXITCODE)"
    }
    Write-Host "  [ OK ] Claude Code CLI (claude mcp add --scope user)" -ForegroundColor Green
}

